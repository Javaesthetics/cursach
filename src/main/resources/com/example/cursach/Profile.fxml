<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="mainPane" prefHeight="550.0" prefWidth="400.0" style="-fx-background-color: linear-gradient(to bottom right, #9D9101, #CDBE70); -fx-border-color: rgba(0,0,0,0.1); -fx-border-width: 2;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cursach.controllers.ProfileController">
    <children>
        <Rectangle arcHeight="40.0" arcWidth="40.0" fill="#ffffff26" height="510.0" layoutX="15.0" layoutY="20.0" stroke="TRANSPARENT" width="370.0" />

        <Text fill="#793d3d" layoutX="123.0" layoutY="55.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Мій профіль">
            <font>
                <Font name="Garamond Bold" size="28.0" />
            </font>
        </Text>

        <ImageView fx:id="avatarImage" fitHeight="120.0" fitWidth="120.0" layoutX="140.0" layoutY="75.0" pickOnBounds="true" preserveRatio="true">
            <clip>
                <Circle centerX="60" centerY="60" radius="60" />
            </clip>
        </ImageView>

        <Circle centerX="200.0" centerY="135.0" fill="TRANSPARENT" radius="61.0" stroke="#d2b48c" strokeWidth="3.0" />

        <Button fx:id="changeAvatarButton" layoutX="160.0" layoutY="202.0" mnemonicParsing="false" style="-fx-background-color: #FFBD88; -fx-text-fill: #793d3d; -fx-font-size: 11px; -fx-background-radius: 15; -fx-cursor: hand; -fx-font-weight: bold; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2;" text="Оновити фото">
         <font>
            <Font name="Garamond Bold" size="12.0" />
         </font></Button>

        <Text fx:id="loginText" fill="#793d3d" layoutX="50.0" layoutY="245.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Завантаження..." textAlignment="CENTER" wrappingWidth="300.0">
            <font>
                <Font name="Garamond Bold" size="22.0" />
            </font>
        </Text>

        <Text fx:id="emailText" fill="#545454" layoutX="50.0" layoutY="270.0" strokeType="OUTSIDE" strokeWidth="0.0" text="email@example.com" textAlignment="CENTER" wrappingWidth="300.0">
            <font>
                <Font name="Garamond Italic" size="16.0" />
            </font>
        </Text>

        <VBox fx:id="favoritesContainer" layoutX="30.0" layoutY="300.0" spacing="10.0">
            <children>
                <Text fx:id="favoritesLabel" fill="#793d3d" strokeType="OUTSIDE" strokeWidth="0.0" text="Моя галерея обраного:">
                    <font>
                        <Font name="Garamond Bold" size="18.0" />
                    </font>
                </Text>

                <ListView fx:id="favoritesList" prefHeight="150.0" prefWidth="340.0" style="-fx-background-color: #FAF0E6; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2; -fx-font-family: 'Garamond';" />
            </children>
        </VBox>

        <Button fx:id="closeButton" layoutX="130.0" layoutY="495.0" mnemonicParsing="false" prefWidth="140.0" style="-fx-background-color: #793d3d; -fx-text-fill: #FFBD88; -fx-font-weight: bold; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2; -fx-cursor: hand;" text="Закрити" AnchorPane.bottomAnchor="25.0" />
    </children>
</AnchorPane>
