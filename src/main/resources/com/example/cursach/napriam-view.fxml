<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="720.0" style="-fx-background-color: linear-gradient(to bottom right, #9D9101, #CDBE70); -fx-border-color: rgba(0,0,0,0.1); -fx-border-width: 2;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cursach.controllers.NapriamController">
    <children>
        <Rectangle arcHeight="50.0" arcWidth="50.0" fill="#ffffff26" height="460.0" layoutX="15.0" layoutY="20.0" stroke="TRANSPARENT" width="690.0" />

        <HBox alignment="CENTER_LEFT" layoutX="35.0" layoutY="35.0" prefWidth="650.0" spacing="15.0">
            <children>
                <Button fx:id="backButton" mnemonicParsing="false" prefHeight="35.0" prefWidth="35.0" style="-fx-background-color: #793d3d; -fx-text-fill: #FFBD88; -fx-background-radius: 50; -fx-cursor: hand; -fx-font-weight: bold;" text="←" />

                <Text style="-fx-fill: #793d3d; -fx-font-weight: bold;" text="Вибір художньої зали">
                    <font>
                        <Font name="Garamond Bold" size="30.0" />
                    </font>
                </Text>

                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="profileButton" mnemonicParsing="false" prefHeight="35.0" style="-fx-background-color: #FFBD88; -fx-text-fill: #793d3d; -fx-font-weight: bold; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #793d3d; -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 0 20;" text="Мій профіль">
               <font>
                  <Font name="Garamond Bold" size="12.0" />
               </font></Button>
            </children>
        </HBox>

        <HBox alignment="CENTER" layoutX="35.0" layoutY="105.0" prefHeight="35.0" prefWidth="660.0" spacing="30.0">
            <children>
                <Button fx:id="impr" onAction="#handleImprButton" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #FFBD88; -fx-text-fill: #793d3d; -fx-font-weight: bold; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2; -fx-cursor: hand;" text="Імпресіоністи">
               <font>
                  <Font name="Garamond Bold" size="14.0" />
               </font></Button>
                <Button fx:id="modern" onAction="#handleModernButton" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #FFBD88; -fx-text-fill: #793d3d; -fx-font-weight: bold; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2; -fx-cursor: hand;" text="Модерністи">
               <font>
                  <Font name="Garamond Bold" size="14.0" />
               </font></Button>
                <Button fx:id="postimpr" onAction="#handlePostimprButton" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #FFBD88; -fx-text-fill: #793d3d; -fx-font-weight: bold; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2; -fx-cursor: hand;" text="Постімпресіоністи">
               <font>
                  <Font name="Garamond Bold" size="14.0" />
               </font></Button>
            </children>
        </HBox>

        <HBox alignment="CENTER" layoutX="35.0" layoutY="155.0" spacing="30.0">
            <children>
                <Button onAction="#handleInfoImpr" prefWidth="200.0" style="-fx-background-color: #793d3d; -fx-text-fill: #FFBD88; -fx-font-weight: bold; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 1; -fx-cursor: hand; -fx-font-size: 13px;" text="Про Імпресіонізм">
               <font>
                  <Font name="Garamond Bold" size="12.0" />
               </font></Button>
                <Button onAction="#handleInfoModern" prefWidth="200.0" style="-fx-background-color: #793d3d; -fx-text-fill: #FFBD88; -fx-font-weight: bold; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 1; -fx-cursor: hand; -fx-font-size: 13px;" text="Про Модерн">
               <font>
                  <Font name="Garamond Bold" size="12.0" />
               </font></Button>
                <Button onAction="#handleInfoPostImpr" prefWidth="200.0" style="-fx-background-color: #793d3d; -fx-text-fill: #FFBD88; -fx-font-weight: bold; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 1; -fx-cursor: hand; -fx-font-size: 13px;" text="Про Постімпресіонізм">
               <font>
                  <Font name="Garamond Bold" size="12.0" />
               </font></Button>
            </children>
        </HBox>

        <HBox layoutX="35.0" layoutY="226.0" prefHeight="229.0" prefWidth="660.0" spacing="30.0">
            <children>
                <ListView fx:id="imprSp" prefWidth="200.0" style="-fx-background-color: #FAF0E6; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2; -fx-font-size: 14px; -fx-font-family: 'Garamond';" />
                <ListView fx:id="modernsSp" prefWidth="200.0" style="-fx-background-color: #FAF0E6; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2; -fx-font-size: 14px; -fx-font-family: 'Garamond';" />
                <ListView fx:id="postimprSp" prefWidth="200.0" style="-fx-background-color: #FAF0E6; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2; -fx-font-size: 14px; -fx-font-family: 'Garamond';" />
            </children>
        </HBox>
      <Text fill="#793d3d" layoutX="35.0" layoutY="210.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Представники:">
         <font>
            <Font name="Garamond Bold" size="19.0" />
         </font>
      </Text>
    </children>
</AnchorPane>
