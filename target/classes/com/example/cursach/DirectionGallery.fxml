<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="480.0" prefWidth="700.0" style="-fx-background-color: linear-gradient(to bottom right, #9D9101, #CDBE70); -fx-border-color: rgba(0,0,0,0.1); -fx-border-width: 2;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cursach.controllers.DirectionGalleryController">

    <children>
        <Rectangle arcHeight="50.0" arcWidth="50.0" fill="#ffffff26" height="440.0" layoutX="15.0" layoutY="20.0" stroke="TRANSPARENT" width="670.0" />

        <HBox alignment="CENTER_LEFT" layoutX="30.0" layoutY="30.0" prefWidth="640.0" spacing="15.0">
            <children>
                <Button fx:id="backButton" mnemonicParsing="false" prefHeight="35.0" prefWidth="35.0" style="-fx-background-color: #793d3d; -fx-text-fill: #FFBD88; -fx-background-radius: 50; -fx-cursor: hand; -fx-font-weight: bold;" text="←" />

                <Text fx:id="headerText" style="-fx-fill: #793d3d; -fx-font-weight: bold;" text="Назва зали">
                    <font>
                        <Font name="Garamond Bold" size="27.0" />
                    </font>
                </Text>

                <StackPane HBox.hgrow="ALWAYS" /> <Button fx:id="profileButton" mnemonicParsing="false" prefHeight="35.0" style="-fx-background-color: #FFBD88; -fx-text-fill: #793d3d; -fx-font-weight: bold; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #793d3d; -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 0 20;" text="Мій профіль" />
            </children>
        </HBox>

        <ListView fx:id="paintingList" layoutX="35.0" layoutY="85.0" prefHeight="295.0" prefWidth="260.0" style="-fx-background-color: #FAF0E6; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2; -fx-font-size: 15px;" />

        <StackPane layoutX="325.0" layoutY="85.0" onMouseClicked="#handleImageClick" prefHeight="200.0" prefWidth="340.0" style="-fx-cursor: hand;">
            <children>
                <ImageView fx:id="paintingImage" fitHeight="200.0" fitWidth="330.0" pickOnBounds="true">
                    <clip>
                        <Rectangle arcHeight="40.0" arcWidth="40.0" height="200.0" width="330.0" />
                    </clip>
                </ImageView>
                <Rectangle arcHeight="40.0" arcWidth="40.0" fill="TRANSPARENT" height="204.0" mouseTransparent="true" stroke="#d2b48c" strokeWidth="5.0" width="336.0" />
            </children>
        </StackPane>

        <TextArea fx:id="paintingDescription" editable="false" layoutX="325.0" layoutY="305.0" prefHeight="130.0" prefWidth="340.0" style="-fx-control-inner-background: #FAF0E6; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 1.5; -fx-font-family: 'Garamond'; -fx-font-size: 15px;" wrapText="true" />

        <HBox layoutX="35.0" layoutY="400.0" prefHeight="35.0" prefWidth="260.0" spacing="15.0">
            <children>
                <Button fx:id="reviewButton" mnemonicParsing="false" prefHeight="40.0" prefWidth="122.0" style="-fx-background-color: #FFBD88; -fx-text-fill: #793d3d; -fx-font-weight: bold; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2; -fx-cursor: hand;" text="Додати відгук">
               <font>
                  <Font name="Garamond Bold" size="12.0" />
               </font></Button>
                <Button fx:id="addToProfileButton" mnemonicParsing="false" prefHeight="40.0" prefWidth="123.0" style="-fx-background-color: #793d3d; -fx-text-fill: #FFBD88; -fx-font-weight: bold; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2; -fx-cursor: hand;" text="Додати в обране">
               <font>
                  <Font name="Garamond Bold" size="12.0" />
               </font></Button>
            </children>
        </HBox>

    </children>
</AnchorPane>
