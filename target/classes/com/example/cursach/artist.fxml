<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="480.0" prefWidth="720.0" style="-fx-background-color: linear-gradient(to bottom right, #9D9101, #CDBE70); -fx-border-color: rgba(0,0,0,0.1); -fx-border-width: 2;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cursach.controllers.ArtistController">

   <children>
      <Rectangle arcHeight="50.0" arcWidth="50.0" fill="#ffffff26" height="440.0" layoutX="15.0" layoutY="20.0" stroke="TRANSPARENT" width="690.0" />

      <HBox alignment="CENTER_LEFT" layoutX="30.0" layoutY="30.0" prefWidth="660.0" spacing="15.0">
         <children>
            <HBox spacing="10.0">
               <children>
                  <Button fx:id="backButton" style="-fx-background-color: #793d3d; -fx-text-fill: #FFBD88; -fx-background-radius: 50; -fx-cursor: hand; -fx-min-width: 35; -fx-min-height: 35;" text="←" />
                  <Button fx:id="forwardButton" style="-fx-background-color: #793d3d; -fx-text-fill: #FFBD88; -fx-background-radius: 50; -fx-cursor: hand; -fx-min-width: 35; -fx-min-height: 35;" text="→" />
               </children>
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="profileButton" style="-fx-background-color: #FFBD88; -fx-text-fill: #793d3d; -fx-font-weight: bold; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #793d3d; -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 8 20;" text="Мій профіль" />
         </children>
      </HBox>

      <VBox layoutX="35.0" layoutY="85.0" prefWidth="280.0" spacing="12.0">
         <children>
            <Text style="-fx-fill: #793d3d; -fx-font-weight: bold;" text="Галерея художників:">
               <font>
                  <Font name="Garamond Bold" size="27.0" />
               </font>
            </Text>
            <ComboBox fx:id="filterComboBox" prefHeight="35.0" prefWidth="280.0" promptText="Оберіть напрям" style="-fx-background-color: #FAF0E6; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c;" />
            <ListView fx:id="artistList" prefHeight="220.0" prefWidth="280.0" style="-fx-background-color: #FAF0E6; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2;" />

            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <Button fx:id="addButton" prefWidth="85.0" style="-fx-background-color: #FFBD88; -fx-text-fill: #793d3d; -fx-font-weight: bold; -fx-background-radius: 15; -fx-cursor: hand; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2;" text="Додати">
                     <font>
                        <Font name="Garamond Bold" size="12.0" />
                     </font></Button>
                  <Button fx:id="editButton" prefWidth="85.0" style="-fx-background-color: #FFBD88; -fx-text-fill: #793d3d; -fx-font-weight: bold; -fx-background-radius: 15; -fx-cursor: hand; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2;" text="Змінити">
                     <font>
                        <Font name="Garamond Bold" size="12.0" />
                     </font></Button>
                  <Button fx:id="deleteButton" prefWidth="85.0" style="-fx-background-color: #793d3d; -fx-text-fill: #FFBD88; -fx-font-weight: bold; -fx-background-radius: 15; -fx-cursor: hand; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2;" text="Видалити">
                     <font>
                        <Font name="Garamond Bold" size="12.0" />
                     </font></Button>
               </children>
            </HBox>
         </children>
      </VBox>

      <VBox alignment="TOP_CENTER" layoutX="371.0" layoutY="59.0" minHeight="-Infinity" minWidth="-Infinity" prefHeight="389.0" prefWidth="319.0" spacing="15.0">
         <children>
            <StackPane fx:id="imageContainer" onMouseClicked="#handleImageClick" prefHeight="250.0" prefWidth="350.0" style="-fx-cursor: hand;">
               <children>
                  <ImageView fx:id="artistImage" fitHeight="180.0" fitWidth="269.0" pickOnBounds="true">
                     <clip>
                        <Rectangle arcHeight="40.0" arcWidth="40.0" height="250.0" width="350.0" />
                     </clip>
                  </ImageView>
                  <Rectangle arcHeight="40.0" arcWidth="40.0" fill="TRANSPARENT" height="204.0" mouseTransparent="true" stroke="#d2b48c" strokeWidth="5.0" width="316.0" />
               </children>
            </StackPane>
            <Button fx:id="viewPaintingsButton" prefHeight="56.0" prefWidth="260.0" style="-fx-background-color: #793d3d; -fx-text-fill: #FFBD88; -fx-font-weight: bold; -fx-background-radius: 15; -fx-cursor: hand; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2;" text="Відкрити галерею картин">
               <font>
                  <Font name="Garamond Bold" size="12.0" />
               </font></Button>

            <TextArea fx:id="artistDescription" editable="false" prefHeight="121.0" prefWidth="319.0" style="-fx-control-inner-background: #FAF0E6; -fx-background-color: transparent; -fx-border-color: #d2b48c; -fx-border-radius: 15; -fx-border-width: 1.5; -fx-font-family: 'Garamond'; -fx-font-size: 15px; -fx-background-radius: 15;" wrapText="true" />
         </children>
      </VBox>
   </children>
</AnchorPane>
