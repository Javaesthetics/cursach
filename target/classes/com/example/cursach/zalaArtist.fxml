<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="500.0" prefWidth="720.0" style="-fx-background-color: linear-gradient(to bottom right, #9D9101, #CDBE70); -fx-border-color: rgba(0,0,0,0.1); -fx-border-width: 2;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cursach.controllers.ZalaArtistController">
   <children>
      <Rectangle arcHeight="50.0" arcWidth="50.0" fill="#ffffff26" height="460.0" layoutX="15.0" layoutY="20.0" stroke="TRANSPARENT" width="690.0" />

      <HBox alignment="CENTER_LEFT" layoutX="35.0" layoutY="35.0" prefWidth="650.0" spacing="15.0">
         <children>
            <Button fx:id="backButton" mnemonicParsing="false" prefHeight="35.0" prefWidth="35.0" style="-fx-background-color: #793d3d; -fx-text-fill: #FFBD88; -fx-background-radius: 50; -fx-cursor: hand; -fx-font-weight: bold;" text="←" />

            <Text fx:id="titleText" style="-fx-fill: #793d3d; -fx-font-weight: bold;" text="Назва зали">
               <font>
                  <Font name="Garamond Bold" size="30.0" />
               </font>
            </Text>

            <Region HBox.hgrow="ALWAYS" />

            <Button fx:id="profileButton" mnemonicParsing="false" prefHeight="35.0" style="-fx-background-color: #FFBD88; -fx-text-fill: #793d3d; -fx-font-weight: bold; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #793d3d; -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 0 20;" text="Мій профіль" />
         </children>
      </HBox>

      <ListView fx:id="vvv" layoutX="35.0" layoutY="95.0" prefHeight="290.0" prefWidth="250.0" style="-fx-background-color: #FAF0E6; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2; -fx-font-size: 15px; -fx-font-family: 'Garamond';" />

      <Button fx:id="nextButton" layoutX="35.0" layoutY="410.0" mnemonicParsing="false" prefHeight="35.0" prefWidth="250.0" style="-fx-background-color: #793d3d; -fx-text-fill: #FFBD88; -fx-font-weight: bold; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 2; -fx-cursor: hand;" text="Переглянути картини" />

      <StackPane layoutX="335.0" layoutY="95.0" onMouseClicked="#handleImageClick" prefHeight="220.0" prefWidth="340.0" style="-fx-cursor: hand;">
         <children>
            <ImageView fx:id="artistImage" fitHeight="210.0" fitWidth="330.0" pickOnBounds="true">
               <clip>
                  <Rectangle arcHeight="40.0" arcWidth="40.0" height="210.0" width="330.0" />
               </clip>
            </ImageView>
            <Rectangle arcHeight="40.0" arcWidth="40.0" fill="TRANSPARENT" height="214.0" mouseTransparent="true" stroke="#d2b48c" strokeWidth="5.0" width="336.0" />
         </children>
      </StackPane>

      <TextArea fx:id="artistDescription" editable="false" layoutX="335.0" layoutY="335.0" prefHeight="110.0" prefWidth="340.0" style="-fx-control-inner-background: #FAF0E6; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #d2b48c; -fx-border-width: 1.5; -fx-font-family: 'Garamond'; -fx-font-size: 15px;" wrapText="true">
         <font>
            <Font name="Garamond Bold" size="12.0" />
         </font></TextArea>
   </children>
</AnchorPane>
